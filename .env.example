# Optional: overrides default unlock code "grabmapssg" baked into the app when unset.
# Prefer GitHub Actions variable/secret `VITE_FLEET_PASSWORD` for production overrides.
VITE_FLEET_PASSWORD=

# Optional POST URL for Apps Script Web App (must end in /exec).
# Paste into GitHub Actions **Secret or Variable** named exactly VITE_INGEST_URL before deploy.
# When unset at build time, Submit shows “Not sent — no server.”
VITE_INGEST_URL=
